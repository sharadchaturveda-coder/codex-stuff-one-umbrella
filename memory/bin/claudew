#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
export PYTHONPATH="$ROOT/src"

exec python3 -m codex_memory.cli launch --backend claude --cwd "$PWD" --claude-bin "${CLAUDE_BIN:-claude}" -- --dangerously-skip-permissions "$@"
